	<!-- Borosh Pantheon -->
	
	<element name="Shakti" type="Deity" source="Jay's Guide To Maa" id="ID_JAY_DEITY_SHAKTI">
		<description>
			<p class="flavor">The Matron goddess is considered the source of the entire universe. Nature incarnate, Generous, Righteous, blesser of birth, marriages, and crops.</p>
		</description>
		<setters>
			<set name="setting">Maa</set>
			<set name="alignment">LG</set>
			<set name="domains">Nature, Life</set>
			<set name="symbol">Tigress</set>
			<set name="gender">female</set>
		</setters>
		<sheet>
			<description>The Matron goddess is considered the source of the entire universe. Nature incarnate, Generous, Righteous, blesser of birth, marriages, and crops.</description>
		</sheet>
	</element>
	
	<element name="Kaal Raatri" type="Deity" source="Jay's Guide To Maa" id="ID_JAY_DEITY_KAALRAATRI">
		<description>
			<p class="flavor">Death Incarnate, the mother of nightmares and necromancy. She embraces what is deiscarded.</p>
		</description>
		<setters>
			<set name="setting">Maa</set>
			<set name="alignment">CG</set>
			<set name="domains">Death, Grave, War</set>
			<set name="symbol">A garland of skulls</set>
			<set name="gender">female</set>
		</setters>
		<sheet>
			<description>Death Incarnate, the mother of nightmares and necromancy. She embraces what is deiscarded.</description>
		</sheet>
	</element>
	
	<element name="Shoonya" type="Deity" source="Jay's Guide To Maa" id="ID_JAY_DEITY_SHOONYA">
